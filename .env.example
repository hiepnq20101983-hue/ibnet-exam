# Cấu hình Google Sheet & Drive
# Đường dẫn đến API Web App của Google Sheets
NEXT_PUBLIC_GOOGLE_SHEET_URL=""

# ID Thư mục Google Drive lưu trữ các tệp đề thi (.html)
GOOGLE_DRIVE_FOLDER_ID=""

# Mã PIN bảo mật cho trang Giáo viên (/teacher)
# Mặc định: 123456 nếu chưa đặt
NEXT_PUBLIC_TEACHER_PIN="123456"

# --- CẤU HÌNH BẬT/TẮT TÍNH NĂNG (FEATURE FLAGS) ---

# Cấu hình không lấy dữ liệu đề thi trên GitHub (Local Assets)
# Nếu đặt là "true", hệ thống sẽ bỏ qua thư mục public/assets/exams, chỉ hiển thị đề từ Google Drive
DISABLE_GIT_EXAMS="false"
